# -*- coding: utf-8-unix -*-

[color]
        ui = auto

[alias]
        a = add
        ap = add -patch
        au = add --update
        br = branch
        co = checkout
        ci = commit -v
        cp = cherry-pick
        d = diff
        dc = diff --cached
        f = fetch --prune
        fa = fetch --all --prune
        l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
        m = merge
        ma = merge --abort
        ra = rebase --abort
        rh = reset --hard
        ri = rebase -i
        rv = remote -v
        p = pull
        st = status
        s = stash
        su = submodule foreach git pull origin master

[core]
        editor = vim

