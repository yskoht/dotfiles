# -*- coding: utf-8-unix -*-

[color]
        ui = auto

[alias]
        br = branch
        co = checkout
        ci = commit
        d = diff
        dc = diff --cached
        f = fetch --prune
        hist = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
        ri = rebase -i
        p = pull
        st = status

[core]
        editor = vim

